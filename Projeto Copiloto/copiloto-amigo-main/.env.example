# Edge Function secrets devem ser configurados no Supabase, nunca no frontend.
# Fluxo recomendado para o MVP com Claude / Anthropic:
# pnpm dlx supabase secrets set LLM_PROVIDER=anthropic
# pnpm dlx supabase secrets set ANTHROPIC_API_KEY=...
# pnpm dlx supabase secrets set ANTHROPIC_MODEL=claude-sonnet-4-20250514
# pnpm dlx supabase secrets set ALLOW_MOCK_ANALYSIS=false
#
# Fluxo alternativo com OpenAI:
# pnpm dlx supabase secrets set LLM_PROVIDER=openai
# pnpm dlx supabase secrets set OPENAI_API_KEY=...
# pnpm dlx supabase secrets set OPENAI_MODEL=gpt-5.5
# pnpm dlx supabase secrets set ALLOW_MOCK_ANALYSIS=false
#
# Fluxo alternativo com Gemini:
# pnpm dlx supabase secrets set LLM_PROVIDER=gemini
# pnpm dlx supabase secrets set GEMINI_API_KEY=...
# pnpm dlx supabase secrets set GEMINI_MODEL=gemini-3.5-flash
