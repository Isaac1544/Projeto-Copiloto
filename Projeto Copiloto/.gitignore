# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Python / caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / build
node_modules/
dist/
build/
.next/
coverage/

# Environment / secrets
.env
.env.*
!.env.example

# Logs
*.log

# Temporary files
tmp/
temp/

# Sensitive raw data
data/raw/
data/private/
data/sensitive/

# Sensitive spreadsheet exports
*.xlsx
*.xls
*.tsv
*.jsonl
*.parquet

# CSV policy:
# Block CSV by default
*.csv

# Allow approved processed/anonymized CSVs
!data/processed/
!data/processed/*-anonimizados.csv
!data/processed/chunks-rag.csv
!data/processed/kb-artigos-normalizados.csv

# Environment secrets and local keys
secrets/
*.pem
*.key

# Local databases
*.db
*.sqlite
*.sqlite3
